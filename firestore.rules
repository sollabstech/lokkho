// firestore.rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Users can read/write only their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Coin history subcollection
      match /coinHistory/{historyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Test history subcollection
      match /testHistory/{testId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Tests collection — anyone authenticated can read
    match /tests/{testId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only via Firebase Console or Cloud Functions
    }

    // Leaderboard — anyone authenticated can read
    match /leaderboard/{period}/users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Study Materials — anyone authenticated can read
    match /studyMaterials/{materialId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only
    }
  }
}
